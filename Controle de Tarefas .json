    },
    {
      "parameters": {
        "promptType": "define",
        "text": "=Analise a seguinte tarefa e determine sua prioridade. Hoje é {{ $json._hoje }}.\n\nTarefa: {{ $json.task }}\nDescrição: {{ $json.description }}\nPrioridade Informada: {{ $json.priority }}\nData Agendada: {{ $json.date }}\nHorário: {{ $json.time }}\n\nConsidere quantos dias faltam até a data agendada para calibrar a urgência e o tempo estimado. Retorne APENAS este JSON preenchido, sem nenhum texto adicional:\n{\"priority\":\"\",\"recommendation\":\"\",\"estimatedTime\":\"\"}",
        "options": {
          "systemMessage": "Você é um assistente especializado em gestão de tarefas e produtividade. Analise tarefas e forneça recomendações claras e objetivas em português. Responda SEMPRE em formato JSON puro, sem markdown, sem ```json, sem explicações. Apenas o objeto JSON."
        }
      },
      "id": "28c7282f-9237-4cdd-835e-bb01ded4ea7a",
      "name": "Analisar Prioridade Tarefa",
      "type": "@n8n/n8n-nodes-langchain.agent",
      "typeVersion": 3.1,
      "position": [1360, 204]
    },
    {
      "parameters": {
        "jsCode": "const agentOut = $input.first().json;\nconst taskData = $('Combinar Dados').item.json;\nconst raw = agentOut.output || '';\nlet parsed;\ntry {\n  const match = raw.match(/\\{[\\s\\S]*\\}/);\n  parsed = JSON.parse(match ? match[0] : raw);\n} catch(e) {\n  parsed = {\n    priority: 'Não definida',\n    recommendation: 'Analisar manualmente',\n    estimatedTime: 'Não definido'\n  };\n}\nreturn [{ json: { ...taskData, output: parsed } }];"
      },
