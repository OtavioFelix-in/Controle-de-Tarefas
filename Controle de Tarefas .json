    {
      "parameters": {
        "jsCode": "const taskData = $('Calcular Data e Hora Atual').item.json;\nconst namedayData = $input.first().json;\nconst namedayName = (namedayData.data && namedayData.data.us) ? namedayData.data.us : 'Não disponível';\nreturn [{ json: { ...taskData, _nameday: namedayName } }];"
      },
      "id": "cc112233-4455-6677-8899-aabbccddeeff",
      "name": "Combinar Dados",
      "type": "n8n-nodes-base.code",
