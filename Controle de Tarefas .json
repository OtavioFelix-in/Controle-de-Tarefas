    {
      "parameters": {
        "jsCode": "const now = new Date();\nconst brOptions = { timeZone: 'America/Sao_Paulo' };\n\nconst day   = now.toLocaleDateString('pt-BR', { ...brOptions, day: '2-digit' });\nconst month = now.toLocaleDateString('pt-BR', { ...brOptions, month: '2-digit' });\nconst year  = now.toLocaleDateString('pt-BR', { ...brOptions, year: 'numeric' });\nconst hour  = now.toLocaleTimeString('pt-BR', { ...brOptions, hour: '2-digit', hour12: false });\n\nconst todayStr = `${day}/${month}/${year}`;\nconst hourStr  = hour.padStart(2, '0');\n\nreturn $input.all().map(item => ({\n  json: {\n    ...item.json,\n    _hoje: todayStr,\n    _hora: hourStr\n  }\n}));"
      },
